{
  "version": "v3.0-unified",
  "date": "2026-02-18",
  "description": "Canonical webscraper pipeline config (merges dt-refs + dt-scrape + dt-v2.*)",
  "pipeline_stages": {
    "01_extract": {
      "input": "00-Inbox/*.url or direct URL",
      "tool": "webscraper skill v1",
      "output": "10-20 References (Ames/Chao template)",
      "quality_gate": "PMID/DOI grep, 10+ refs minimum"
    },
    "02_atomize": {
      "input": "66-Literature/Refs/*.md",
      "output": "7-10 Atomic notes per source",
      "template": "Zettel_ atomic format",
      "hooks": ["VitD", "IBD", "adipic", "IR", "miR-21/155", "butyrate"]
    },
    "03_connect": {
      "input": "33-Atomic/*.md",
      "output": "55-MOCs updates + Dataview links",
      "bidirectional": true,
      "eternal": "NO-MISS: All connected"
    }
  },
  "phd_hooks": ["adipic","IR","VitD","microbiome","stress-autoimmune","miR-21","miR-155","butyrate"],
  "model_tiers": {
    "Brain": "moonshot/kimi-k2.5",
    "Muscle": "openrouter/x-ai/grok-4.1-fast"
  },
  "batch_limits": {
    "file_ops": 25,
    "urls_per_batch": 5
  },
  "status": "canonical",
  "previous_configs": ["dt-refs-v2.1", "dt-scrape-v1.8", "dt-v2.0", "dt-v2.1.1-ms-final", "dt-v2.1-athro-test"]
}